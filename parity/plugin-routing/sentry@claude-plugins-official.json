      ],
      "rationale": "Cursor reads .claude-plugin/ natively and its variant emits mcp.json from .mcp.json, so all component groups are already covered with no action."
    },
    "agy": {
      "outcome": "re-point-mcp-lsp",
      "actions": [
        "emit the sentry HTTP MCP via agy's user-global mcp-installer (src/agy/mcp-installer.ts)",
        "reimplement the 30 SDK skills as Lisa-native skills stamped synced-from: sentry@claude-plugins-official@1.0.0 (or claude-only where Claude-specific)",
        "reimplement the seer command as a Lisa-native skill stamped synced-from: sentry@claude-plugins-official@1.0.0"
      ],
      "rationale": "The dominant component is the sentry HTTP MCP, re-pointed via agy's mcp-installer; the seer command and the SDK skills are reimplemented as Lisa skills (agy's fan-out does not carry curated third-party plugins)."
    },
    "copilot": {
      "outcome": "re-point-mcp-lsp",
      "actions": [
        "emit the sentry HTTP MCP as an inline mcpServers entry on Copilot's manifest",
        "reimplement the 30 SDK skills as Lisa-native skills stamped synced-from: sentry@claude-plugins-official@1.0.0 (or enable Copilot's native equivalent where applicable)",
        "reimplement the seer command as a Lisa-native skill stamped synced-from: sentry@claude-plugins-official@1.0.0"
      ],
      "rationale": "The dominant component is the sentry HTTP MCP, emitted inline on Copilot's manifest; the seer command and the SDK skills are reimplemented as Lisa skills so no component group is dropped."
