      "i18n-js": "^4.5.1",
      "patch-package": "^8.0.0",
      "react-hook-form": "^7.70.0",
      "tar": ">=7.5.11",
      "text-encoding-polyfill": "^0.6.7",
      "usehooks-ts": "^3.1.1",
      "zod": "^4.3.5"
    },
    "devDependencies": {
