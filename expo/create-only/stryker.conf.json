{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.ts",
    "enableFindRelatedTests": true
  },
  "reporters": ["clear-text", "progress", "html"],
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "incremental": true,
  "mutate": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.d.ts",
    "!src/**/*.stories.tsx"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  }
}
