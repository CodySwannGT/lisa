{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "extends": ["./typescript.json"],
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "jsdoc",
    "promise",
    "node"
  ],
  "ignorePatterns": [
    "build/**",
    "dist/**",
    ".build/**",
    "coverage/**",
    "node_modules/**",
    "cdk.out/**"
  ]
}
