{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "extends": ["./typescript.json"],
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "jsdoc",
    "promise",
    "react",
    "react-perf",
    "jsx-a11y"
  ],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "build/**",
    "dist/**",
    ".build/**",
    "coverage/**",
    "node_modules/**",
    ".expo/**",
    "ios/**",
    "android/**",
    "web-build/**",
    "components/ui/**"
  ]
}
