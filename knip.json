{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/**/*.ts", "scripts/**/*.ts", "scripts/**/*.mjs"],
  "project": ["src/**/*.ts", "scripts/**/*.ts", "scripts/**/*.mjs"],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/tests/**",
    "**/test/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/node_modules/**"
  ],
  "ignoreDependencies": [
    "@ast-grep/cli",
    "@commitlint/cli",
    "@eslint/eslintrc",
    "@jest/globals",
    "@jest/test-sequencer",
    "esbuild-register",
    "eslint-config-prettier",
    "eslint-plugin-react-hooks",
    "husky",
    "jiti",
    "jscodeshift",
    "lint-staged",
    "prettier",
    "ts-jest",
    "ts-morph",
    "tsx"
  ],
  "ignoreBinaries": [
    "ast-grep",
    "eslint",
    "expo",
    "gh",
    "husky",
    "knip",
    "oxlint",
    "playwright",
    "prettier",
    "serve",
    "standard-version",
    "tsc",
    "tsx",
    "vitest"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "devDependencies": "off"
  }
}
