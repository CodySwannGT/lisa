{
  "force": {
    "scripts": {
      "lint": "eslint . --quiet",
      "format:check": "prettier --check .",
      "format": "prettier --check . --write",
      "test": "vitest run",
      "test:unit": "vitest run --exclude='**/integration/**'",
      "test:cov": "vitest run --coverage",
      "test:watch": "vitest",
      "lint:fix": "eslint . --fix",
      "lint:slow": "eslint . --config eslint.slow.config.ts --quiet",
      "typecheck": "tsc --noEmit",
      "knip": "knip",
      "knip:fix": "knip --fix",
      "sg:scan": "ast-grep scan",
      "prepare": "node -e \"if (process.env.INIT_CWD && process.env.INIT_CWD.includes('.serverless')) { process.exit(0); }\" && husky install || true"
    },
    "resolutions": {
      "@isaacs/brace-expansion": "^5.0.1",
      "axios": ">=1.15.0"
    },
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "axios": ">=1.15.0"
    }
  },
  "defaults": {
    "scripts": {
      "build": "tsc",
      "test:integration": "vitest run tests/integration --passWithNoTests"
    },
    "engines": {
      "npm": "please-use-bun",
      "yarn": "please-use-bun",
      "pnpm": "please-use-bun",
      "bun": "1.3.8",
      "node": "22.21.1"
    }
  },
  "merge": {
    "trustedDependencies": [
      "@ast-grep/cli",
      "@codyswann/lisa",
      "@sentry/cli"
    ]
  }
}
