{
  "force": {
    "scripts": {
      "setup:deploy-key": "setup-deploy-key",
      "lint": "oxlint && eslint . --quiet",
      "format:check": "prettier --check .",
      "format": "prettier --check . --write",
      "test": "vitest run",
      "test:unit": "vitest run --exclude='**/integration/**'",
      "test:cov": "vitest run --coverage",
      "test:mutation": "node scripts/lisa-mutation.mjs",
      "test:watch": "vitest",
      "lint:fix": "oxlint --fix && eslint . --fix",
      "lint:slow": "eslint . --config eslint.slow.config.ts --quiet",
      "typecheck": "tsc --noEmit",
      "knip:check": "knip",
      "knip:fix": "knip --fix",
      "sg:scan": "ast-grep scan",
      "prepare": "node -e \"if (process.env.INIT_CWD?.includes('.serverless')) process.exit(0); process.exit(1);\" || husky install || true"
    },
    "devDependencies": {
      "eslint-plugin-oxlint": "^1.62.0",
      "oxlint": "^1.62.0",
      "oxlint-tsgolint": "^0.22.1",
      "@stryker-mutator/core": "^9.0.0",
      "@stryker-mutator/vitest-runner": "^9.0.0"
    },
    "resolutions": {
      "@isaacs/brace-expansion": "^5.0.1",
      "brace-expansion": ">=5.0.7",
      "axios": ">=1.15.2",
      "esbuild": ">=0.28.1",
      "handlebars": ">=4.7.9",
      "lodash": ">=4.18.1",
      "multer": ">=2.2.0",
      "undici": ">=6.27.0",
      "vite": ">=8.0.16",
      "ws": ">=8.21.0",
      "form-data": ">=4.0.6",
      "systeminformation": ">=5.27.14"
    },
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "brace-expansion": ">=5.0.7",
      "axios": ">=1.15.2",
      "esbuild": ">=0.28.1",
      "handlebars": ">=4.7.9",
      "lodash": ">=4.18.1",
      "multer": ">=2.2.0",
      "undici": ">=6.27.0",
      "vite": "^8.0.16",
      "ws": ">=8.21.0",
      "form-data": ">=4.0.6",
      "systeminformation": ">=5.27.14"
    }
  },
  "defaults": {
    "devDependencies": {
      "@codyswann/lisa": "^2.106.0"
    },
    "scripts": {
      "build": "tsc",
      "postinstall": "[ -n \"$CI\" ] || LISA_BOOTSTRAP=1 node node_modules/@codyswann/lisa/dist/index.js --yes --skip-git-check . 2>/dev/null || true",
      "test:integration": "vitest run tests/integration --passWithNoTests"
    },
    "engines": {
      "npm": "please-use-bun",
      "yarn": "please-use-bun",
      "pnpm": "please-use-bun",
      "bun": "1.3.8",
      "node": "22.21.1"
    }
  },
  "merge": {
    "trustedDependencies": [
      "@ast-grep/cli",
      "@codyswann/lisa",
      "@sentry/cli"
    ]
  },
  "remove": {
    "scripts": [
      "knip"
    ]
  }
}
