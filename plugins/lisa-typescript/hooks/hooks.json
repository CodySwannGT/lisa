{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/block-suppress-directives.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/format-on-edit.sh"
          },
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/sg-scan-on-edit.sh"
          },
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/lint-on-edit.sh"
          }
        ]
      }
    ]
  }
}
