{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/enforce-verification-gate.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/block-no-verify.sh",
        "matcher": "Bash"
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/parity-safety-net.sh",
        "matcher": "Bash"
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/enforce-verification-gate.sh"
      }
    ],
    "stop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/enforce-verification-gate.sh"
      }
    ],
    "sessionStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/install-pkgs.sh",
        "matcher": "startup"
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/setup-jira-cli.sh"
      }
    ],
    "subagentStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/enforce-verification-gate.sh"
      }
    ]
  }
}
