{
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "./hooks/inject-rules.sh"
        }
      ]
    }
  ],
  "SubagentStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "./hooks/inject-rules.sh"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "./hooks/rubocop-on-edit.sh"
        },
        {
          "type": "command",
          "command": "./hooks/sg-scan-on-edit.sh"
        }
      ]
    }
  ]
}
