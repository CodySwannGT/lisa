{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inject-rules.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inject-rules.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/rubocop-on-edit.sh"
          },
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/sg-scan-on-edit.sh"
          }
        ]
      }
    ]
  }
}
