{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/block-no-verify.sh"
          },
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/parity-safety-net.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/install-pkgs.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inject-rules.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/setup-jira-cli.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inject-rules.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inject-flow-context.sh"
          }
        ]
      }
    ]
  }
}
