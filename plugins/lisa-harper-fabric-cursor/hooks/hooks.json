{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/block-generated-artifact-edits.sh",
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "postToolUse": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/enforce-config-extensions.sh",
        "matcher": "Write|Edit|MultiEdit"
      }
    ]
  }
}
