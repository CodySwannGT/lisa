{
  "extends": "./typescript.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "allowJs": false,
    "skipLibCheck": true,
    "types": ["node", "vitest"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": [
    "dist",
    "coverage",
    "node_modules",
    "harper-app/resources.js",
    "harper-app/web/**/*.js"
  ]
}
