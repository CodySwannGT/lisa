{
  "force": {
    "scripts": {
      "setup:deploy-key": "setup-deploy-key",
      "watch": "tsc -w",
      "cdk": "cdk",
      "build": "tsc --noEmit",
      "prepare": "husky install || true",
      "test": "vitest run",
      "test:unit": "vitest run --exclude='**/integration/**'",
      "test:integration": "vitest run tests/integration --passWithNoTests",
      "test:cov": "vitest run --coverage",
      "test:mutation": "node scripts/lisa-mutation.mjs",
      "test:watch": "vitest",
      "lint": "oxlint && eslint . --quiet",
      "lint:fix": "oxlint --fix && eslint . --fix"
    },
    "dependencies": {
      "aws-cdk-github-oidc": "^2.4.1",
      "constructs": "^10.4.5",
      "source-map-support": "^0.5.21"
    },
    "devDependencies": {
      "aws-cdk": "^2.1127.0",
      "esbuild": "^0.28.1",
      "vite": "^8.0.16",
      "vitest": "^4.1.0",
      "@vitest/coverage-v8": "^4.1.0",
      "eslint-plugin-oxlint": "^1.62.0",
      "oxlint": "^1.62.0",
      "oxlint-tsgolint": "^0.22.1",
      "@stryker-mutator/core": "^9.0.0",
      "@stryker-mutator/vitest-runner": "^9.0.0"
    },
    "bin": {
      "infrastructure": "bin/infrastructure.js"
    },
    "private": true,
    "overrides": {
      "aws-cdk-lib": "$aws-cdk-lib",
      "esbuild": "$esbuild",
      "vite": "$vite"
    },
    "resolutions": {
      "aws-cdk-lib": "$aws-cdk-lib",
      "esbuild": "$esbuild",
      "vite": "$vite"
    }
  },
  "defaults": {
    "dependencies": {
      "@aws-cdk/aws-amplify-alpha": "^2.259.0-alpha.0",
      "aws-cdk-lib": "2.259.0"
    },
    "devDependencies": {
      "@codyswann/lisa": "^2.106.0"
    },
    "engines": {
      "npm": ">= 10.9.4",
      "yarn": "please-use-npm",
      "pnpm": "please-use-npm",
      "bun": "please-use-npm",
      "node": "22.21.1"
    }
  }
}
